package org.firstinspires.ftc.teamcode;

import com.qualcomm.robotcore.eventloop.opmode.LinearOpMode;
import com.qualcomm.robotcore.hardware.DcMotor;
import com.qualcomm.robotcore.eventloop.opmode.TeleOp;
import com.qualcomm.robotcore.hardware.DcMotorEx;
import com.qualcomm.robotcore.util.ElapsedTime;
import com.qualcomm.robotcore.hardware.VoltageSensor;
import com.qualcomm.robotcore.util.Range;
import org.firstinspires.ftc.robotcore.external.navigation.CurrentUnit;

@TeleOp(name="TestTeleopCurrentAmps", group="Linear Opmode")
public class TestTeleopCurrentAmps extends LinearOpMode {

    // Hardware - Flywheel shooter motor(s)
    private DcMotorEx shooter1Motor = null;
    private DcMotorEx shooter2Motor = null;
    public DcMotor kickerWheel = null;
    public DcMotor intakeMotor = null;
    public DcMotor frontLeftMotor = null;
    public DcMotor backRightMotor = null;
    public DcMotor frontRightMotor = null;
    public DcMotor backLeftMotor = null;
    double slowSpeed = 0.8;  // Slow speed factor like as in math factors
    double fastSpeed = 1.2;  // Fast speed factor like as in math factors
    double currentSpeed = slowSpeed;
    double MAX_POWER = 0.9;
    double kF = 0.00042;  // Adjust this after testing

    // PID Controller for velocity control
    private PIDController pidController;

    //voltage sensor
    private VoltageSensor myControlHubVoltageSensor;


    // Target velocity in ticks per second
    private double targetVelocity = 0;

    // Preset velocities for shooting into GOAL from different distances
    // These values need to be tuned for your specific robot!
    private static final double CLOSE_SHOT_VELOCITY = 1050;   // Close range shot
    private static final double MID_SHOT_VELOCITY = 1350;     // Mid-range shot
    private static final double FAR_SHOT_VELOCITY = 2800;     // Far range/across field
    private static final double STOP_VELOCITY = 0;

    @Override
    public void runOpMode() {
        double leftBack;
        double rightBack;
        double rightFront;
        double leftFront;

        // Initialize hardware
        shooter1Motor = hardwareMap.get(DcMotorEx.class, "shooter1Motor");
        shooter2Motor = hardwareMap.get(DcMotorEx.class, "shooter2Motor");

        // CRITICAL FIX: Use RUN_WITHOUT_ENCODER for manual PID control
        // RUN_USING_ENCODER has built-in velocity control that fights your PID!
        shooter1Motor.setMode(DcMotor.RunMode.RUN_WITHOUT_ENCODER);
        shooter2Motor.setMode(DcMotor.RunMode.RUN_WITHOUT_ENCODER);

        // CRITICAL FIX: Use BRAKE for better control response
        shooter1Motor.setZeroPowerBehavior(DcMotor.ZeroPowerBehavior.BRAKE);
        shooter2Motor.setZeroPowerBehavior(DcMotor.ZeroPowerBehavior.BRAKE);

        shooter1Motor.setCurrentAlert(8.0, CurrentUnit.AMPS); // Set safe threshold
        shooter2Motor.setCurrentAlert(8.0, CurrentUnit.AMPS); // Set safe threshold

        kickerWheel = hardwareMap.get(DcMotor.class, "kickerwheelMotor");
        intakeMotor = hardwareMap.get(DcMotor.class, "intakeMotor");
        frontLeftMotor = hardwareMap.get(DcMotor.class, "leftFront");
        backLeftMotor = hardwareMap.get(DcMotor.class, "leftBack");
        frontRightMotor = hardwareMap.get(DcMotor.class, "rightFront");
        backRightMotor = hardwareMap.get(DcMotor.class, "rightBack");

        myControlHubVoltageSensor = hardwareMap.get(VoltageSensor.class, "Control Hub");

        backRightMotor.setDirection(DcMotor.Direction.FORWARD);
        frontRightMotor.setDirection(DcMotor.Direction.REVERSE);
        backLeftMotor.setDirection(DcMotor.Direction.FORWARD);
        frontLeftMotor.setDirection(DcMotor.Direction.REVERSE);

        intakeMotor.setDirection(DcMotor.Direction.FORWARD);

        // AGGRESSIVE PID values for fast response
        // These are 10x more aggressive - should hit target velocity quickly
        // Tune down if oscillation occurs
        pidController = new PIDController(0.0068 , 0.0006, 0);

        telemetry.addData("Status", "Initialized - DECODE 2025-2026");
        telemetry.addData("Game", "Launch ARTIFACTS into GOAL");
        telemetry.addData("Controls", "HOLD A=Close | HOLD B=Mid | HOLD Y=Far | X=Stop");
        telemetry.addData("PID Tuning", "Gamepad1 D-Pad Up/Down adjusts target");
        telemetry.update();

        waitForStart();

        ElapsedTime runtime = new ElapsedTime();

        while (opModeIsActive()) {
            // Preset velocity controls - MUST HOLD BUTTON to maintain shooter speed
            // Release button to stop shooter
            if (gamepad2.a) {
                targetVelocity = CLOSE_SHOT_VELOCITY;
            } else if (gamepad2.b) {
                targetVelocity = MID_SHOT_VELOCITY;
            } else if (gamepad2.y) {
                targetVelocity = FAR_SHOT_VELOCITY;
            } else if (gamepad2.x) {
                targetVelocity = STOP_VELOCITY;
                pidController.reset();
            } else {
                // If no button is held, stop the shooter
                targetVelocity = STOP_VELOCITY;
                pidController.reset();
            }

            // Kicker wheel control
            if (gamepad2.right_bumper) {
                kickerWheel.setPower(-1);
            } else {
                kickerWheel.setPower(0);
            }

            // Intake control
            if (gamepad2.right_trigger > 0) {
                intakeMotor.setPower(-1);
            } else if (gamepad2.left_trigger > 0) {
                intakeMotor.setPower(1);  // Reverse intake
            } else {
                intakeMotor.setPower(0);
            }

            // Speed mode control
            if (gamepad1.left_trigger > 0) {
                currentSpeed = slowSpeed;  // Set to slow mode
            } else if (gamepad1.right_trigger > 0) {
                currentSpeed = fastSpeed;  // Set to fast mode
            }

            // REMOVED: The dpad_down override that was bypassing PID
            // This was setting shooter power directly and ignoring PID control

            // Mecanum drive control
            double y = -gamepad1.left_stick_y; // Forward/Reverse
            double x = gamepad1.left_stick_x; // Strafe left/right
            double rx = gamepad1.right_stick_x; // Turn left/right

            rightFront = -y + x + rx;
            leftFront = y + x + rx;
            rightBack = y + x - rx;
            leftBack = -y + x - rx;

            leftBack *= currentSpeed;
            rightBack *= currentSpeed;
            leftFront *= currentSpeed;
            rightFront *= currentSpeed;

            // Set motor powers
            backRightMotor.setPower(rightBack);
            frontRightMotor.setPower(rightFront);
            backLeftMotor.setPower(leftBack);
            frontLeftMotor.setPower(leftFront);

            // Fine-tune velocity with D-pad during testing
            if (gamepad1.dpad_up) {
                targetVelocity += 50;
            } else if (gamepad1.dpad_down) {
                targetVelocity -= 50;
            }

            // Ensure velocity is non-negative
            targetVelocity = Math.max(0, targetVelocity);

            // Get current velocity from motor encoder
            double currentVelocity = shooter1Motor.getVelocity();

            // Step 1: Calculate feedforward (baseline power needed)
            double feedforward = targetVelocity * kF;

            // Step 2: Calculate PID correction for error
            double pidCorrection = pidController.calculate(currentVelocity, targetVelocity);

            // Step 3: Combine them
            double totalPower = feedforward + pidCorrection;

            // Step 4: Clamp to safe range
            totalPower = Range.clip(totalPower, 0, MAX_POWER);
            // Check if shooter is at target velocity (ready to shoot)
            boolean readyToShoot = pidController.atTarget(currentVelocity, targetVelocity, 50);

            double presentVoltage;
            presentVoltage = myControlHubVoltageSensor.getVoltage();

            telemetry.addData("Voltage Sensor",myControlHubVoltageSensor.getVoltage());

            // Apply PID-controlled power to shooter motors
            shooter1Motor.setPower(totalPower);
            shooter2Motor.setPower(totalPower);

            // Display telemetry for driver feedback
            telemetry.addData("Game", "DECODE 2025-2026");
            telemetry.addData("---", "---");
            telemetry.addData("Target Velocity", "%.0f ticks/sec", targetVelocity);
            telemetry.addData("Current Velocity", "%.0f ticks/sec", currentVelocity);
            telemetry.addData("Encoder Ticks", "%.0f ticks/sec", targetVelocity);
            telemetry.addData("=== POWER BREAKDOWN ===", "");
            telemetry.addData("Feedforward", "%.3f (%.0f%%)", feedforward, feedforward/MAX_POWER*100);
            telemetry.addData("PID Correction", "%.3f", pidCorrection);
            telemetry.addData("Motor Power", "%.3f", totalPower);
            telemetry.addData("Velocity Error", "%.0f ticks/sec", targetVelocity - currentVelocity);
            telemetry.addData("Ready to Shoot", readyToShoot ? "✓ YES - FIRE!" : "✗ Spinning up...");
            telemetry.addData("---", "---");
            telemetry.addData("Shot Presets", "HOLD BUTTON TO RUN");
            telemetry.addData("  Close (HOLD A)", "%d ticks/sec", (int)CLOSE_SHOT_VELOCITY);
            telemetry.addData("  Mid (HOLD B)", "%d ticks/sec", (int)MID_SHOT_VELOCITY);
            telemetry.addData("  Far (HOLD Y)", "%d ticks/sec", (int)FAR_SHOT_VELOCITY);
            telemetry.addData("---", "---");
            telemetry.addData("Speed Mode", currentSpeed == slowSpeed ? "Slow" : "Fast");
            telemetry.update();
        }
    }

}
