package org.firstinspires.ftc.teamcode;

import com.pedropathing.geometry.BezierLine;
import com.pedropathing.geometry.Pose;
import com.pedropathing.paths.PathChain;
import com.pedropathing.util.Timer;
import com.qualcomm.robotcore.eventloop.opmode.OpMode;
import com.qualcomm.robotcore.eventloop.opmode.Autonomous;
import com.pedropathing.follower.Follower;

import org.firstinspires.ftc.teamcode.pedroPathing.Constants;

@Autonomous
public class SampleAutoPath2 extends OpMode {

    private Follower follower;
    private Timer pathTimer, opModeTimer;

    public enum PathState {
        DRIVE_STARTPOS_SHOOT_POS,
        SHOOT_PRELOAD,
        DRIVE_SHOOT_POS_FIRSTPOSE,
        DRIVE_FIRSTPOSE_SHOOTPOS,
        DRIVE_SHOOTPOS_POINTTWOPOSE,
        DRIVE_POINTTWOPOSE_SECONDPOSE,
        DRIVE_SECONDPOSE_SHOOTPOS,
        DRIVE_SHOOTPOS_POINTHREEPOSE,
        DRIVE_POINTHREEPOSE_THIRDPOSE,
        DRIVE_THIRDPOSE_SHOOTPOS,
        DRIVE_SHOOTPOS_ENDPOSE,
        IDLE
    }

    private PathState pathState;

    private final Pose startPose = new Pose(20.10,122.92, Math.toRadians(138));
    private final Pose shootPose = new Pose(59.32,84.81, Math.toRadians(138));
    private final Pose firstPose = new Pose(17.69, 84.56, Math.toRadians(180));
    private final Pose pointTwoPose = new Pose(50.46, 58.95, Math.toRadians(180));
    private final Pose secondPose = new Pose(14.31, 59.26, Math.toRadians(180));
    private final Pose pointThreePose = new Pose(57.64, 36.48, Math.toRadians(180));
    private final Pose thirdPose = new Pose(13.81, 36.15, Math.toRadians(180));
    private final Pose endPose = new Pose(60.09, 108.55, Math.toRadians(90));

    private PathChain driveStartPosShootPos, driveShootPoseFirstPos, driveFirstPosShootPos,
            driveShootPosPointTwoPos, drivePointTwoPosSecondPose, driveSecondPoseShootPos,
            driveShootPosPointThreePose, drivePointThreePoseThirdPose, driveThirdPoseShootPos,
            driveShootPosEndPose;

    @Override
    public void init() {
        pathTimer = new Timer();
        opModeTimer = new Timer();
        follower = Constants.createFollower(hardwareMap);

        buildPaths();
        follower.setPose(startPose);

        pathState = PathState.DRIVE_STARTPOS_SHOOT_POS;
    }

    @Override
    public void start() {
        opModeTimer.resetTimer();
        setPathState(pathState);
    }

    @Override
    public void loop() {
        follower.update();
        statePathUpdate();

        telemetry.addData("path state", pathState);
        telemetry.addData("x", follower.getPose().getX());
        telemetry.addData("y", follower.getPose().getY());
        telemetry.addData("heading", Math.toDegrees(follower.getPose().getHeading()));
        telemetry.addData("Path time", pathTimer.getElapsedTimeSeconds());
        telemetry.update();
    }

    private void buildPaths() {

        driveStartPosShootPos = follower.pathBuilder()
                .addPath(new BezierLine(startPose, shootPose))
                .setLinearHeadingInterpolation(startPose.getHeading(), shootPose.getHeading())
                .build();

        driveShootPoseFirstPos = follower.pathBuilder()
                .addPath(new BezierLine(shootPose, firstPose))
                .setConstantHeadingInterpolation(Math.toRadians(180))
                .build();

        driveFirstPosShootPos = follower.pathBuilder()
                .addPath(new BezierLine(firstPose, shootPose))
                .setLinearHeadingInterpolation(firstPose.getHeading(), shootPose.getHeading())
                .build();

        driveShootPosPointTwoPos = follower.pathBuilder()
                .addPath(new BezierLine(shootPose, pointTwoPose))
                .setConstantHeadingInterpolation(Math.toRadians(180))
                .build();

        drivePointTwoPosSecondPose = follower.pathBuilder()
                .addPath(new BezierLine(pointTwoPose, secondPose))
                .setLinearHeadingInterpolation(pointTwoPose.getHeading(), secondPose.getHeading())
                .build();

        driveSecondPoseShootPos = follower.pathBuilder()
                .addPath(new BezierLine(secondPose, shootPose))
                .setLinearHeadingInterpolation(secondPose.getHeading(), shootPose.getHeading())
                .build();

        driveShootPosPointThreePose = follower.pathBuilder()
                .addPath(new BezierLine(shootPose, pointThreePose))
                .setLinearHeadingInterpolation(shootPose.getHeading(), pointThreePose.getHeading())
                .build();

        drivePointThreePoseThirdPose = follower.pathBuilder()
                .addPath(new BezierLine(pointThreePose, thirdPose))
                .setLinearHeadingInterpolation(pointThreePose.getHeading(), thirdPose.getHeading())
                .build();

        driveThirdPoseShootPos = follower.pathBuilder()
                .addPath(new BezierLine(thirdPose, shootPose))
                .setLinearHeadingInterpolation(thirdPose.getHeading(), shootPose.getHeading())
                .build();

        driveShootPosEndPose = follower.pathBuilder()
                .addPath(new BezierLine(shootPose, endPose))
                .setLinearHeadingInterpolation(shootPose.getHeading(), endPose.getHeading())
                .build();
    }

    private void statePathUpdate() {
        switch (pathState) {

            case DRIVE_STARTPOS_SHOOT_POS:
                if (!follower.isBusy()) {
                    follower.followPath(driveStartPosShootPos, true);
                    setPathState(PathState.SHOOT_PRELOAD);
                    telemetry.addLine("Driving from start to shoot position");
                }
                break;

            case SHOOT_PRELOAD:
                if (!follower.isBusy() && pathTimer.getElapsedTimeSeconds() > 2) {
                    // TODO: shoot preload here
                    follower.followPath(driveShootPoseFirstPos, true);
                    setPathState(PathState.DRIVE_SHOOT_POS_FIRSTPOSE);
                    telemetry.addLine("Finished preload + moving to first pose");
                }
                break;

            case DRIVE_SHOOT_POS_FIRSTPOSE:
                if (!follower.isBusy()) {
                    follower.followPath(driveFirstPosShootPos, true);
                    setPathState(PathState.DRIVE_FIRSTPOSE_SHOOTPOS);
                    telemetry.addLine("Reached first pose, going back to shoot");
                }
                break;

            case DRIVE_FIRSTPOSE_SHOOTPOS:
                if (!follower.isBusy() && pathTimer.getElapsedTimeSeconds() > 2) {
                    // TODO: shoot again here
                    follower.followPath(driveShootPosPointTwoPos, true);
                    setPathState(PathState.DRIVE_SHOOTPOS_POINTTWOPOSE);
                    telemetry.addLine("Shot and moving to second point");
                }
                break;

            case DRIVE_SHOOTPOS_POINTTWOPOSE:
                if (!follower.isBusy()) {
                    follower.followPath(drivePointTwoPosSecondPose, true);
                    setPathState(PathState.DRIVE_POINTTWOPOSE_SECONDPOSE);
                    telemetry.addLine("Driving to second point");
                }
                break;

            case DRIVE_POINTTWOPOSE_SECONDPOSE:
                if (!follower.isBusy()) {
                    follower.followPath(driveSecondPoseShootPos, true);
                    setPathState(PathState.DRIVE_SECONDPOSE_SHOOTPOS);
                    telemetry.addLine("Picked up second row");
                }
                break;

            case DRIVE_SECONDPOSE_SHOOTPOS:
                if (!follower.isBusy() && pathTimer.getElapsedTimeSeconds() > 2) {
                    // TODO: shoot second row here
                    follower.followPath(driveShootPosPointThreePose, true);
                    setPathState(PathState.DRIVE_SHOOTPOS_POINTHREEPOSE);
                    telemetry.addLine("Shooting second row, moving to third point");
                }
                break;

            case DRIVE_SHOOTPOS_POINTHREEPOSE:
                if (!follower.isBusy()) {
                    follower.followPath(driveShootPosPointThreePose, true); // non-blocking
                    setPathState(PathState.DRIVE_POINTHREEPOSE_THIRDPOSE);
                    telemetry.addLine("Driving to third point");
                }
                break;

            case DRIVE_POINTHREEPOSE_THIRDPOSE:
                if (!follower.isBusy()) {
                    follower.followPath(driveThirdPoseShootPos, true); // non-blocking
                    setPathState(PathState.DRIVE_THIRDPOSE_SHOOTPOS);
                    telemetry.addLine("Picked up 3rd row");
                }
                break;
            case DRIVE_THIRDPOSE_SHOOTPOS:
                if (!follower.isBusy() && pathTimer.getElapsedTimeSeconds() > 2) {
                    // TODO: shoot 3rd row here
                    follower.followPath(driveShootPosEndPose, true);
                    setPathState(PathState.DRIVE_SHOOTPOS_ENDPOSE);
                    telemetry.addLine("Shooting 3rd row, moving to end pose");
                }
                break;

            case DRIVE_SHOOTPOS_ENDPOSE:
                if (!follower.isBusy()) {
                    setPathState(PathState.IDLE);
                    telemetry.addLine("Done with autonomous path");
                }
                break;

            case IDLE:
                // Do nothing
                break;
        }
    }

    private void setPathState(PathState newState) {
        pathState = newState;
        pathTimer.resetTimer();
    }
}
